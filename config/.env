# Cyanide Honeypot Configuration

# Core
HONEYPOT_HOSTNAME=server01
LOG_PATH=var/log/cyanide
DATA_PATH=var/lib/cyanide
FS_PICKLE=data/cyanide/fs.pickle
TXTCMDS_PATH=data/cyanide/txtcmds

# Server
SERVER_HOST=0.0.0.0
OS_PROFILE=random
MAX_SESSIONS=100
MAX_SESSIONS_PER_IP=5
SESSION_TIMEOUT=300
QUARANTINE_MAX_SIZE_MB=500

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# ML
ML_ENABLED=false
ML_METRICS_PORT=9090
ML_ANOMALIES_LOG=var/log/cyanide/cyanideML-anomalies-log.json
ML_LOG=var/log/cyanide/cyanideML-log.json
MODEL_PATH=ai_models/cyanideML/cyanideML.pkl
ONLINE_LEARNING=false

# SSH
SSH_ENABLED=true
SSH_PORT=2222
SSH_RSA_KEYING=true
SSH_VERSION=SSH-2.0-OpenSSH_8.2p1 Ubuntu-4ubuntu0.5

# Telnet
TELNET_ENABLED=true
TELNET_PORT=2223

# SMTP
SMTP_ENABLED=true
SMTP_PORT=2525
SMTP_TARGET_HOST=127.0.0.1
SMTP_TARGET_PORT=25255

# Output
JSON_LOG=true

# Cleanup
CLEANUP_ENABLED=true
CLEANUP_INTERVAL=3600
CLEANUP_RETENTION_DAYS=7
CLEANUP_PATHS=var/log/cyanide,var/lib/cyanide

# External Services
VIRUSTOTAL_ENABLED=true
VIRUSTOTAL_API_KEY=
