#!/usr/bin/env python3
import sys
import os
import argparse
from pathlib import Path

# Fix path
sys.path.append(os.path.join(os.getcwd(), 'src'))

from cyanide.core.config import load_config
from cyanide.core.cleanup import CleanupManager

def main():
    parser = argparse.ArgumentParser(description="Cyanide Honeypot Cleanup Tool")
    parser.add_argument("--days", type=int, help="Override retention days (default: use config)", default=None)
    parser.add_argument("--dry-run", action="store_true", help="Show what would be deleted without deleting")
    parser.add_argument("--force", action="store_true", help="Skip confirmation")
    parser.add_argument("--all", action="store_true", help="Delete ALL log data (equivalent to --days 0)")
    parser.add_argument("--config", default="config/cyanide.cfg", help="Path to config file")

    args = parser.parse_args()
    
    # Load config
    cfg_path = Path(args.config)
    if not cfg_path.exists():
        print(f"Error: Config not found at {cfg_path}")
        sys.exit(1)
        
    config = load_config(cfg_path)
    if not config:
        print("Error: Could not load config.")
        sys.exit(1)
        
    manager = CleanupManager(config)
    
    days = args.days
    if args.all:
        days = 0
    elif days is None:
        days = manager.retention_days
        
    print(f"[*] Cyanide Cleanup Tool")
    print(f"[*] Mode: {'DRY RUN' if args.dry_run else 'LIVE'}")
    print(f"[*] Removing files older than {days} days from: {', '.join(manager.target_paths)}")
    
    if not args.dry_run and not args.force:
        confirm = input("Are you sure? [y/N] ")
        if confirm.lower() != 'y':
            print("Aborted.")
            sys.exit(0)
            
    try:
        stats = manager.cleanup_files(retention_days_override=days, dry_run=args.dry_run)
        
        if stats.get("status") == "disabled" and args.days is None:
            print("[!] Cleanup is disabled in config. Use --days to force run.")
        else:
            print("\n" + "="*30)
            print(f"Deleted files: {stats.get('deleted', 0)}")
            print(f"Bytes freed:   {stats.get('bytes_freed', 0)}")
            print(f"Errors:        {stats.get('errors', 0)}")
            print("="*30 + "\n")
            
    except Exception as e:
        print(f"Fatal error: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
