#!/usr/bin/env python3
import sys
import os

# Silence all technical noise (deprecation warnings and debug logs) at the earliest stage
os.environ['PYTHONWARNINGS'] = 'ignore'
import warnings
import logging
warnings.filterwarnings("ignore")
logging.basicConfig(level=logging.ERROR)
logging.getLogger().setLevel(logging.ERROR)

import subprocess
import signal
import time
import argparse
import json
import re
from pathlib import Path

# --- Path Configuration ---
# Get the directory where this script is located
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
# The project root is one level up from the scripts/ directory
ROOT_DIR = os.path.dirname(SCRIPT_DIR)

PID_FILE = os.path.join(ROOT_DIR, "var/run/cyanide.pid")
STDOUT_LOG = os.path.join(ROOT_DIR, "var/log/cyanide/cyanide.out")
STDERR_LOG = os.path.join(ROOT_DIR, "var/log/cyanide/cyanide.err")
CONFIG_FILE = os.path.join(ROOT_DIR, "config/cyanide.cfg")
SRC_DIR = os.path.join(ROOT_DIR, "src")
EASTEREGG_FILE = os.path.join(ROOT_DIR, "data/assets/logo.txt")

# Ensure src is in path
if SRC_DIR not in sys.path:
    sys.path.insert(0, SRC_DIR)

# --- Service Management ---

def start():
    # Ensure dirs exist
    os.makedirs(os.path.dirname(PID_FILE), exist_ok=True)
    os.makedirs(os.path.dirname(STDOUT_LOG), exist_ok=True)

    if os.path.exists(PID_FILE):
        print("Cyanide already running (pid file exists).")
        return

    # Load and print configuration info
    try:
        from cyanide.core.config import load_config
        from cyanide.core.aesthetics import print_startup_banner
        config = load_config(Path(CONFIG_FILE))
        print_startup_banner(config)
    except Exception as e:
        print(f"[!] Info: Could not load extra config info: {e}")

    print("Starting Cyanide...")
    env = os.environ.copy()
    env["PYTHONPATH"] = SRC_DIR
    
    with open(STDOUT_LOG, "w") as out, open(STDERR_LOG, "w") as err:
        p = subprocess.Popen(
            [sys.executable, os.path.join(SRC_DIR, "cyanide/main.py")], 
            cwd=ROOT_DIR,
            env=env,
            stdout=out, 
            stderr=err
        )
    
    with open(PID_FILE, "w") as f:
        f.write(str(p.pid))
    print(f"Cyanide started with PID {p.pid}")

def stop():
    if not os.path.exists(PID_FILE):
        print("Cyanide not running.")
        return
        
    with open(PID_FILE, "r") as f:
        pid = int(f.read().strip())
    
    print(f"Stopping Cyanide (PID {pid})...")
    try:
        os.kill(pid, signal.SIGTERM)
        time.sleep(1)
    except ProcessLookupError:
        print("Process not found.")
    
    if os.path.exists(PID_FILE):
        os.remove(PID_FILE)
    print("Stopped.")

def restart():
    stop()
    start()

def stats():
    try:
        import requests
    except ImportError:
        print("[!] Error: 'requests' library required for stats. Install with: pip install requests")
        return

    from datetime import timedelta
    port = 9090 
    try:
        from cyanide.core.config import load_config
        config = load_config(Path(CONFIG_FILE))
        port = int(config.get("metrics", {}).get("port", 9090))
    except Exception:
        pass

    try:
        url = f"http://localhost:{port}/stats"
        response = requests.get(url, timeout=5)
        response.raise_for_status()
        data = response.json()
        
        print("\n" + "\033[1;36m" + "="*50 + "\033[0m")
        print("\033[1;36m CYANIDE STATISTICS\033[0m")
        print("\033[1;36m" + "="*50 + "\033[0m")
        uptime = data.get('uptime_seconds', 0)
        print(f"[*] Uptime:          {timedelta(seconds=uptime)}")
        print(f"[*] Active Sessions: \033[1;32m{data.get('active_sessions', 0)}\033[0m")
        print(f"[*] Total Sessions:  {data.get('total_sessions', 0)}")
        print(f"[*] Malware Scans:   {data.get('malware_scans', 0)} (Detected: \033[1;31m{data.get('malicious_detected', 0)}\033[0m)")
        
        if data.get('top_ips'):
            print("\n\033[1;33m--- Top Attacker IPs ---\033[0m")
            for ip, count in data['top_ips'].items():
                print(f" {ip:<20} | {count} hits")
        print("\033[1;36m" + "="*50 + "\033[0m\n")
    except Exception as e:
        print(f"\033[1;31m[!] Error fetching stats: {e}\033[0m")

# --- Cleanup Logic ---

def clean(args):
    try:
        from cyanide.core.config import load_config
        from cyanide.core.cleanup import CleanupManager
        
        config = load_config(Path(CONFIG_FILE))
        if not config:
            print("Error: Could not load config.")
            return
            
        manager = CleanupManager(config)
        days = args.days
        if args.all:
            days = 0
        elif days is None:
            days = manager.retention_days
            
        print(f"[*] Cyanide Cleanup")
        print(f"[*] Mode: {'DRY RUN' if args.dry_run else 'LIVE'}")
        print(f"[*] Removing files older than {days} days from: {', '.join(manager.target_paths)}")
        
        if not args.dry_run and not args.force:
            confirm = input("Are you sure? [y/N] ")
            if confirm.lower() != 'y':
                print("Aborted.")
                return
                
        stats = manager.cleanup_files(retention_days_override=days, dry_run=args.dry_run)
        print("\n" + "="*30)
        print(f"Deleted files: {stats.get('deleted', 0)}")
        print(f"Bytes freed:   {stats.get('bytes_freed', 0)}")
        print(f"Errors:        {stats.get('errors', 0)}")
        print("="*30 + "\n")
            
    except Exception as e:
        print(f"Cleanup error: {e}")

# --- Replay Logic ---

def replay(args):
    log_path = args.log_file
    if not os.path.exists(log_path):
        print(f"Error: File {log_path} not found.")
        return

    try:
        import ast
        start_time = 0.0
        header = {
            "version": 2, "width": 120, "height": 40, "timestamp": 0,
            "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}
        }
        
        with open(log_path, 'r', encoding='utf-8', errors='ignore') as f:
            lines = f.readlines()
            
        if not lines: return
            
        match = re.search(r'started at (\d+\.\d+)', lines[0])
        if match:
            start_time = float(match.group(1))
            header["timestamp"] = int(start_time)
            
        print(json.dumps(header))
        
        for line in lines[1:]:
            parts = line.split(" ", 2)
            if len(parts) < 3: continue
            if "[OUT]" not in parts[1]: continue
                
            ts = float(parts[0])
            try:
                content = ast.literal_eval(parts[2].strip())
            except:
                content = parts[2]
                
            rel_time = max(0, ts - start_time)
            print(json.dumps([round(rel_time, 6), "o", content]))
            
    except Exception as e:
        print(f"Replay error: {e}", file=sys.stderr)

# --- Filesystem Management ---

def import_fs(args):
    source = Path(args.source)
    if not source.exists():
        print(f"[!] Error: Source file {source} does not exist.")
        return

    # Determine destination name
    name = args.name
    if not name:
        name = source.stem
        # Remove 'fs.' prefix if user included it in filename
        if name.startswith('fs.'):
            name = name[3:]
    
    dest_filename = f"fs.{name}.yaml"
    dest_path = Path(ROOT_DIR) / "config/fs-config" / dest_filename
    
    if dest_path.exists() and not args.force:
        confirm = input(f"[?] File {dest_filename} already exists. Overwrite? [y/N] ")
        if confirm.lower() != 'y':
            print("Aborted.")
            return

    try:
        import shutil
        os.makedirs(dest_path.parent, exist_ok=True)
        shutil.copy2(source, dest_path)
        print(f"[*] Successfully imported filesystem as: \033[1;32m{name}\033[0m")
        print(f"[*] Path: {dest_path}")
        print(f"[*] You can now use it with: OS_PROFILE={name} or OS_PROFILE=random")
    except Exception as e:
        print(f"[!] Error importing filesystem: {e}")

# --- Main CLI ---

def main():
    parser = argparse.ArgumentParser(description="Cyanide Honeypot Management Tool")
    subparsers = parser.add_subparsers(dest="command", help="Command to execute")

    # Service subcommands
    subparsers.add_parser("start", help="Start the honeypot")
    subparsers.add_parser("stop", help="Stop the honeypot")
    subparsers.add_parser("restart", help="Restart the honeypot")
    subparsers.add_parser("stats", help="Show statistics")

    # Clean subcommand
    clean_parser = subparsers.add_parser("clean", help="Clean up old logs and quarantined files")
    clean_parser.add_argument("--days", type=int, help="Override retention days")
    clean_parser.add_argument("--dry-run", action="store_true", help="Show what would be deleted")
    clean_parser.add_argument("--force", action="store_true", help="Skip confirmation")
    clean_parser.add_argument("--all", action="store_true", help="Delete ALL log data")

    # Replay subcommand
    replay_parser = subparsers.add_parser("replay", help="Convert TTY log to asciinema format")
    replay_parser.add_argument("log_file", help="Path to the .log file")

    # Import-FS subcommand
    import_parser = subparsers.add_parser("import-fs", help="Import a custom filesystem YAML template")
    import_parser.add_argument("source", help="Path to the source YAML file")
    import_parser.add_argument("--name", help="Name for the profile (default: filename)")
    import_parser.add_argument("-f", "--force", action="store_true", help="Overwrite existing profile")

    args = parser.parse_args()

    # Handle subcommands
    if args.command == "start":
        start()
    elif args.command == "stop":
        stop()
    elif args.command == "restart":
        restart()
    elif args.command == "stats":
        stats()
    elif args.command == "clean":
        clean(args)
    elif args.command == "replay":
        replay(args)
    elif args.command == "import-fs":
        import_fs(args)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
